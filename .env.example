# ─── FlightPulse AI — Environment Variables ───────────────────
# Copy this file to .env and fill in your values
# Do NOT commit .env to version control

# ── Sarvam AI (SkyGPT Copilot) ──────────────────────────────
VITE_SARVAM_API_KEY=your_sarvam_api_key_here

# ── Neo4j AuraDB (Compensation + Missed Connection) ──────────
VITE_NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
VITE_NEO4J_USERNAME=neo4j
VITE_NEO4J_PASSWORD=your_neo4j_password_here

# ── Render (AI Insights Workflows) ───────────────────────────
VITE_RENDER_API_KEY=your_render_api_key_here
VITE_RENDER_SERVICE_ID=your_render_service_id_here

# ── OpenSky Network (Flight Tracker + Airport Intelligence) ──
# These credentials are used SERVER-SIDE only by the Vite proxy plugin.
# They are NEVER exposed in the browser bundle.
# Register at https://opensky-network.org/index.php?option=com_users&view=registration
OPENSKY_CLIENT_ID=your_opensky_client_id
OPENSKY_CLIENT_SECRET=your_opensky_client_secret

# ── Sarvam AI (SkyGPT Copilot) ───────────────────────────────
# These credentials are used SERVER-SIDE only by the Vite proxy plugin.
SARVAM_API_KEY=your_sarvam_api_key_here
